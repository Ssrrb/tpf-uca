@startuml
!pragma layout smetana
left to right direction
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
title 06 — CU-03 Consultar grupos inscriptos\nDiagrama de clases de análisis BCE — RF-04

class "IUConsultaGrupos" as IU <<boundary>> {
  + solicitar(): void
  + mostrarResultado(): void
}

class "ControlConsultaGrupos" as Control <<control>> {
  + consultarGruposInscriptos(): void
}

class "SemestreTFG" as SemestreTFG <<entity>> {
  - temaTentativo: String
  + consultar(): void
}
class "GrupoTFG" as GrupoTFG <<entity>> {
  - temaTentativo: String
  + consultar(): void
}

IU --> Control
Control --> SemestreTFG
Control --> GrupoTFG
SemestreTFG "1" -- "0..*" GrupoTFG : grupos

legend bottom
Trazabilidad: RF-04; RNF-06; Minuta 03.
Modelo de análisis BCE sin detalles de implementación.
endlegend
@enduml
