@startuml
!pragma layout smetana
left to right direction
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
title 04 — CU-02 Inscribir grupo\nDiagrama de clases de análisis BCE — RF-02, RF-03

class "IUInscripcionGrupo" as IU <<boundary>> {
  + solicitar(): void
  + mostrarResultado(): void
}

class "ControlInscripcionGrupo" as Control <<control>> {
  + inscribirGrupo(): void
}

class "SemestreTFG" as SemestreTFG <<entity>> {
  - temaTentativo: String
  + consultar(): void
}
class "Estudiante" as Estudiante <<entity>> {
  - temaTentativo: String
  + consultar(): void
}
class "GrupoTFG" as GrupoTFG <<entity>> {
  - temaTentativo: String
  + consultar(): void
}

IU --> Control
Control --> SemestreTFG
Control --> Estudiante
Control --> GrupoTFG
SemestreTFG "1" -- "0..*" GrupoTFG : grupos
GrupoTFG "1" -- "1..3" Estudiante : integrantes

legend bottom
Trazabilidad: RF-02, RF-03; RNF-02, RNF-04; Minuta 02.
Modelo de análisis BCE sin detalles de implementación.
endlegend
@enduml
