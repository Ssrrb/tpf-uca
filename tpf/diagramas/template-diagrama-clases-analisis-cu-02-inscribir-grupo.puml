@startuml
' Template personalizado — IS1 TPF 2026, Grupo G11
' CU-02: Inscribir grupo.
' Trazabilidad: RF-02, RF-03; RNF-02, RNF-04; Minuta 02.
' Modelo de análisis: expresa responsabilidades y colaboraciones BCE,
' no componentes técnicos, tablas, frameworks ni detalles de implementación.
' FUENTE CANÓNICA OVERARCH: overarch/models/20-cu-02-analisis.edn
' VISTA OVERARCH: :g11.view/cu-02-clases-analisis
' Modificar primero nombres, operaciones, relaciones y tipos en el modelo EDN.

!pragma layout smetana
skinparam style strictuml
skinparam BackgroundColor White
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam class {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #475569
  FontColor #0F172A
  StereotypeFontColor #1E3A8A
}

title CU-02 — Inscribir grupo\nDiagrama de clases de análisis — RF-02 y RF-03

package "Frontera" #EFF6FF {
  class IUInscripcionGrupo <<boundary>> {
    + solicitarInscripcion(): void
    + mostrarFormularioInscripcion(): void
    + ingresarDatosGrupo(temaTentativo: String, integrantes: Estudiante[1..3], medioContacto: String): void
    + mostrarConfirmacionInscripcion(grupo: GrupoTFG): void
    + informarErroresDeInscripcion(errores: String[*]): void
    + informarPertenenciaDuplicada(): void
  }
}

package "Control del caso de uso" #FFF7ED {
  class ControlInscripcionGrupo <<control>> {
    + inscribirGrupo(temaTentativo: String, integrantes: Estudiante[1..3], medioContacto: String, usuarioActual: String): GrupoTFG
    - validarDatosObligatorios(temaTentativo: String, integrantes: Estudiante[1..3], medioContacto: String): Boolean {query}
    - validarCantidadIntegrantes(integrantes: Estudiante[1..3]): Boolean {query}
    - validarPertenenciaUnica(integrantes: Estudiante[1..3], semestre: SemestreTFG): Boolean {query}
  }
}

package "Entidades del dominio" #F0FDF4 {
  class SemestreTFG <<entity>> {
    - identificador: String
    - fechaCierreInscripcion: Date
    + obtenerSemestreVigente(): SemestreTFG {query}
  }

  class Estudiante <<entity>> {
    - identificador: String
    + perteneceAOtroGrupo(semestre: SemestreTFG): Boolean {query}
  }

  class GrupoTFG <<entity>> {
    - temaTentativo: String
    - medioContacto: String
    - estado: EstadoGrupo
    - fechaInscripcion: DateTime
    - usuarioResponsable: String
    + registrarInscripcion(temaTentativo: String, integrantes: Estudiante[1..3], medioContacto: String, semestre: SemestreTFG, fecha: DateTime, usuario: String): void
    + cambiarEstado(nuevoEstado: EstadoGrupo): void
  }

  enum EstadoGrupo <<enumeration>> {
    PENDIENTE_INSCRIPCION
    INSCRIPTO
    TUTOR_ASIGNADO
    EN_ELABORACION_ANTEPROYECTO
    ANTEPROYECTO_ENTREGADO
  }
}

' Reglas de robustez: frontera -> control -> entidades.
IUInscripcionGrupo --> ControlInscripcionGrupo : solicita inscripción
ControlInscripcionGrupo ..> SemestreTFG : consulta semestre
ControlInscripcionGrupo ..> Estudiante : valida pertenencia
ControlInscripcionGrupo ..> GrupoTFG : registra grupo

' Relaciones estructurales del dominio.
SemestreTFG "1" -- "0..*" GrupoTFG : grupos
GrupoTFG "0..*" -- "1..3" Estudiante : integrantes
GrupoTFG --> "1" EstadoGrupo : estado

note right of GrupoTFG
  Restricción RF-03:
  para un mismo SemestreTFG,
  cada Estudiante integra como máximo un GrupoTFG.
end note

legend right
  |= Elemento |= Responsabilidad / fuente |
  | IUInscripcionGrupo | boundary: interacción web; RNF-02 |
  | ControlInscripcionGrupo | control: coordina CU-02 y validaciones |
  | SemestreTFG | entity: contexto de unicidad por semestre; RF-03 |
  | Estudiante | entity: integrante cuya pertenencia se valida; RF-03 |
  | GrupoTFG | entity: tema, 1..3 integrantes, contacto y auditoría; RF-02, RNF-04 |
  | EstadoGrupo | valores cerrados definidos por RF-10 |
endlegend

@enduml
