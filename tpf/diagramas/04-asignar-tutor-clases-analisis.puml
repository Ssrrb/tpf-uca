@startuml
!pragma layout smetana
left to right direction
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
title 08 — CU-04 Asignar tutor\nDiagrama de clases de análisis BCE — RF-05

class "IUAsignacionTutor" as IU <<boundary>> {
  + solicitar(): void
  + mostrarResultado(): void
}

class "ControlAsignacionTutor" as Control <<control>> {
  + asignarTutor(): void
}

class "SemestreTFG" as SemestreTFG <<entity>> {
  - tutorAsignado: String
  + consultar(): void
}
class "GrupoTFG" as GrupoTFG <<entity>> {
  - tutorAsignado: String
  + consultar(): void
}
class "Tutor" as Tutor <<entity>> {
  - tutorAsignado: String
  + consultar(): void
}

IU --> Control
Control --> SemestreTFG
Control --> GrupoTFG
Control --> Tutor
SemestreTFG "1" -- "0..*" GrupoTFG : grupos
GrupoTFG "0..*" -- "0..1" Tutor : tutor asignado

legend bottom
Trazabilidad: RF-05; RNF-03, RNF-04; Minuta 03.
Modelo de análisis BCE sin detalles de implementación.
endlegend
@enduml
